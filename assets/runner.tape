# claude-games Claude Runner demo
# Run: vhs assets/runner.tape

Output assets/runner.gif

Set Theme "GitHub Dark"
Set FontSize 20
Set Width 1200
Set Height 800
Set Padding 40
Set Framerate 15
Set TypingSpeed 80ms

# Launch and go to Runner
Type "node dist/cli.js"
Enter
Sleep 3s
Enter
Sleep 2s

# Start
Space
Sleep 1.5s

# Jump
Space
Sleep 1.2s

# Another jump
Sleep 800ms
Space
Sleep 1.2s

# Duck
Down
Sleep 1s

# Jump
Space
Sleep 1.2s
Space
Sleep 1s

# Duck
Down
Sleep 800ms

# More jumping
Sleep 800ms
Space
Sleep 1.2s
Space
Sleep 1.2s

# Show pause
Type "p"
Sleep 3s

# Resume
Type "p"
Sleep 1s

Space
Sleep 1.2s
Space
Sleep 1s

# Let it play
Sleep 2s

# Quit
Type "q"
Sleep 2s
Type "q"
Sleep 2s
