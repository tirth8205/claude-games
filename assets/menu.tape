# claude-games menu demo
# Run: vhs assets/menu.tape

Output assets/menu.gif

Set Theme "GitHub Dark"
Set FontSize 20
Set Width 1200
Set Height 700
Set Padding 40
Set Framerate 15
Set TypingSpeed 80ms

# Launch
Type "node dist/cli.js"
Enter
Sleep 4s

# Hover on Runner
Sleep 3s

# Switch to Snake
Right
Sleep 3s

# Back to Runner
Left
Sleep 3s

# Quit
Type "q"
Sleep 2s
