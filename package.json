{
  "name": "claude-games",
  "version": "1.0.0",
  "description": "Play games in your terminal while Claude Code works on your tasks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-games": "dist/cli.js"
  },
  "scripts": {
